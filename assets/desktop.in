[Desktop Entry]
Name=NetHack Companion
Version=0.1
Comment=A simple ncurses app to contain useful NetHack character information between runs
Type=Application
Keywords=Games
Terminal=false
Categories=Games
Exec=gnome-terminal --geometry=110x32 -- bash -c '"@CMAKE_BINARY_DIR@/NetHack_Companion"; exec bash'
Icon=@CMAKE_SOURCE_DIR@/assets/nhc_icon.ico